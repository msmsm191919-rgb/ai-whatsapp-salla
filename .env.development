# ----------------------------------------------------
# 🌍 LOCAL DEVELOPMENT CONFIGURATION
# ----------------------------------------------------
PORT=8095
NODE_ENV=development
APP_URL=http://localhost:8095

# ----------------------------------------------------
# 🗄️ DATABASE CONNECTION
# ----------------------------------------------------
SALLA_DATABASE_DIALECT=sqlite

# ----------------------------------------------------
# 🛒 SALLA APP CONFIGURATION
# ----------------------------------------------------
SALLA_OAUTH_CLIENT_ID=mock_dev_id
SALLA_OAUTH_CLIENT_SECRET=mock_dev_secret
SALLA_OAUTH_CLIENT_REDIRECT_URI=http://localhost:8095/oauth/salla/callback
SALLA_WEBHOOK_SECRET=mock_dev_webhook

# ----------------------------------------------------
# 🤖 AI & INTEGRATIONS
# ----------------------------------------------------
OPENAI_API_KEY=your-local-development-openai-key

# ----------------------------------------------------
# 🔐 SECURITY
# ----------------------------------------------------
SESSION_SECRET=dev_session_secret_123456789

# ----------------------------------------------------
# 🌐 ZID & SHOPIFY MOCK MODE (Leave empty for automatic mock)
# ----------------------------------------------------
ZID_CLIENT_ID=
ZID_CLIENT_SECRET=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# ----------------------------------------------------
# 💳 TAP PAYMENTS (Leave empty for automatic success mock)
# ----------------------------------------------------
TAP_PUBLIC_KEY=
TAP_SECRET_KEY=
