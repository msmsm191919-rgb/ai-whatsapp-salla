# .env.staging.example
# ═══════════════════════════════════════════════════════════════════
# 🔒 Staging Environment Configuration Template (Secrets Omitted)
# ═══════════════════════════════════════════════════════════════════

# Core variables
NODE_ENV=staging
HOST=127.0.0.1
PORT=8096

# Database configuration
SALLA_DATABASE_DIALECT=sqlite
SALLA_DATABASE_STORAGE=/opt/mubhir-staging/data/database_staging.sqlite

# WhatsApp authentication path
WWEBJS_AUTH_PATH=/opt/mubhir-staging/data/wwebjs_auth

# Security safe mode & sessions config
STAGING_SAFE_MODE=true
SESSION_COOKIE_NAME=mubhir_staging_sid
SESSION_SECRET=your_staging_random_long_session_secret_string

# Salla OAuth Application Credentials (to be filled from Salla partner portal for staging application)
SALLA_OAUTH_CLIENT_ID=
SALLA_OAUTH_CLIENT_SECRET=
SALLA_OAUTH_CLIENT_REDIRECT_URI=https://staging.mubhirbot.com/oauth/callback

# Webhook credentials
SALLA_WEBHOOK_SECRET=
