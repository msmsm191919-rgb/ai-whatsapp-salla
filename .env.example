# ----------------------------------------------------
# 🌍 SERVER CONFIGURATION
# ----------------------------------------------------
PORT=8095
NODE_ENV=production
APP_URL=https://your-domain.com

# ----------------------------------------------------
# 🗄️ DATABASE CONNECTION
# ----------------------------------------------------
DATABASE_SERVER=localhost
DATABASE_USERNAME=root
DATABASE_PASSWORD=your_password
DATABASE_NAME=salla_whatsapp_saas
# Or SQLite for dev:
# SALLA_DATABASE_DIALECT=sqlite

# ----------------------------------------------------
# 🛒 SALLA APP CONFIGURATION
# Get these from https://partners.salla.sa
# ----------------------------------------------------
SALLA_OAUTH_CLIENT_ID=your_client_id
SALLA_OAUTH_CLIENT_SECRET=your_client_secret
SALLA_OAUTH_CLIENT_REDIRECT_URI=https://your-domain.com/salla/callback
SALLA_WEBHOOK_SECRET=your_webhook_secret

# ----------------------------------------------------
# 🤖 AI & INTEGRATIONS
# ----------------------------------------------------
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------------------------------
# 🔐 SECURITY
# ----------------------------------------------------
SESSION_SECRET=create_a_long_random_string_here_for_security

# ----------------------------------------------------
# 🌐 ZID PLATFORM (https://web.zid.sa/partners)
# اتركها فاضية للوضع التجريبي (Mock)
# ----------------------------------------------------
ZID_CLIENT_ID=
ZID_CLIENT_SECRET=
ZID_REDIRECT_URI=

# ----------------------------------------------------
# 🛍️ SHOPIFY PLATFORM (https://partners.shopify.com)
# اتركها فاضية للوضع التجريبي (Mock)
# ----------------------------------------------------
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_REDIRECT_URI=

# ----------------------------------------------------
# 💳 TAP PAYMENTS (https://www.tap.company/sa/ar)
# ----------------------------------------------------
# اتركها فاضية للوضع التجريبي (Mock Mode — كل دفعة تنجح تلقائياً)
# للإنتاج: احصل عليها من dashboard.tap.company
TAP_PUBLIC_KEY=
TAP_SECRET_KEY=
TAP_WEBHOOK_SECRET=
